#!/bin/bash
#
# Pre-commit hook: 自動使用 Spotless 重新格式化程式碼
#
# 若程式碼格式不符合規範，自動執行 spotless:apply 並重新加入暫存區

set -e

# 取得色彩輸出支援
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m' # No Color
else
    RED=''
    GREEN=''
    YELLOW=''
    NC=''
fi

echo -e "${YELLOW}執行 Spotless 程式碼格式檢查...${NC}"

# 執行 spotless:apply 來自動格式化程式碼
# 使用 --batch 模式避免互動式提示
mvn -q spotless:apply -B

# 檢查是否有檔案被修改
if ! git diff --quiet; then
    echo -e "${YELLOW}程式碼已自動格式化，將修改的檔案重新加入暫存區...${NC}"

    # 重新加入所有已暫存的檔案（包含格式化後的變更）
    git diff --name-only --cached | while read -r file; do
        if [ -f "$file" ]; then
            git add "$file"
        fi
    done

    echo -e "${GREEN}✓ 程式碼格式化完成${NC}"
fi

exit 0
